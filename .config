[smem]
# Core SMEM model parameters
num_banks = 32
word_bytes = 4
dram_latency_cycles = 1
# Warp-synchronous model: a full warp (num_banks threads) enters the arbiter
# atomically, and the bank-parallel arbiter issues up to one request per
# distinct bank per cycle -- so the cap equals num_banks. Set this lower to
# simulate a narrower-port arbiter.
arbiter_issue_width = 32

# Thread model parameters
num_threads = 1

# Per-thread SMEM offsets.
# Use either a list (index = thread_id)...
thread_block_offsets = [0]

# ...or replace with a table:
# [smem.thread_block_offsets]
# "0" = 0
# "1" = 256
